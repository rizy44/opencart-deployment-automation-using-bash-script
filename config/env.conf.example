# Copy this file to config/env.conf and update values for your environment.

# Basic site settings
SITE_NAME="opencart"
DOMAIN="localhost"
WEB_ROOT="/var/www/opencart"

# OpenCart source
OPENCART_VERSION="4.1.0.3"
# Optional custom URL. Leave empty to use GitHub release pattern above.
OPENCART_ZIP_URL=""

# App runtime owner
APP_USER="www-data"
APP_GROUP="www-data"

# Database settings
DB_HOST="localhost"
DB_PORT="3306"
DB_NAME="opencart"
DB_USER="opencart_user"
DB_PASSWORD="ChangeMeStrongPassword"

PHP_FPM_SERVICE="php8.3-fpm"
PHP_FPM_SOCK="/run/php/php8.3-fpm.sock"

# Reports and backup settings
REPORT_ROOT="/opt/ecom-reports"
BACKUP_ROOT="/opt/ecom-backups"
STATE_DIR="/opt/ecom-state"
RETAIN_FULL="7"
RETAIN_INCREMENTAL="14"
